{
  "expo": {
    "name": "Artiou",
    "slug": "museum-guide",
    "scheme": "museumguide",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "艺游需要使用相机拍摄展品图片。",
        "UIBackgroundModes": ["audio"]
      },
      "bundleIdentifier": "com.ottozhang.artiou"
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.ottozrq.museumguide"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-audio",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "664332f3-08d3-4125-86ff-e7f1f01c69aa"
      }
    }
  }
}
