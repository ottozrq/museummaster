{
  "expo": {
    "name": "Artiou",
    "slug": "museum-guide",
    "scheme": "museumguide",
    "version": "1.0.0",
    "newArchEnabled": false,
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "Artiou needs camera access to capture exhibit photos for recognition.",
        "NSPhotoLibraryUsageDescription": "Artiou needs access to your photos so you can choose an image from your library.",
        "UIBackgroundModes": ["audio"]
      },
      "bundleIdentifier": "com.ottozhang.artiou"
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.ottozhang.artiou"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-audio",
      "expo-apple-authentication",
      [
        "react-native-iap",
        {
          "paymentProvider": "Play Store"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "664332f3-08d3-4125-86ff-e7f1f01c69aa"
      }
    }
  }
}
