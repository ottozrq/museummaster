# 运行环境: development | staging | production
# ENV=development

# Flags system (gagaou-style): YAML config + env overrides
# MUSEUMFLAGS_FILE=flags.yml
# MUSEUMFLAGS_TARGET=local

OPENAI_API_KEY=sk-...
OPENAI_MUSEUM_MODEL=gpt-4o
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# Database (DatabaseFlags); default in flags.yml: sqlite:///./museum.db
# DATABASE_URL=sqlite:///./museum.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/museum
# DATABASE_SQL_ECHO=false

# Apple Sign-In (AppleFlags)
# APPLE_CLIENT_ID=com.example.app
